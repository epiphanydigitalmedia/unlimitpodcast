# Adobe Fonts kit ID containing Freight Big Pro.
# Get this from https://fonts.adobe.com/my_fonts → your Unlimit Podcast kit
NEXT_PUBLIC_ADOBE_FONTS_KIT=

# Substack publication handle.
# Used to build embed URLs and subscribe links.
# Current handle: unlimitpodcast (from https://substack.com/@unlimitpodcast)
NEXT_PUBLIC_SUBSTACK_HANDLE=unlimitpodcast

# =============================================================================
# Cron — episode auto-sync (RSS source + Spotify scraper for embed IDs)
# =============================================================================

# Anchor / Spotify-for-Creators RSS feed. Source of truth for new episode
# detection (title, description, duration, audio URL, GUID).
RSS_FEED_URL=https://anchor.fm/s/11288f500/podcast/rss

# Public Spotify show ID. The cron scrapes https://open.spotify.com/show/<id>
# to resolve each episode's spotifyEpisodeId (for the embed iframe). No API
# credentials needed — the show page is public.
SPOTIFY_SHOW_ID=033fC9vZNYBsByh1MQrpam

# GitHub repo write access (used to commit new episode data).
# Create a fine-grained PAT at https://github.com/settings/personal-access-tokens/new
# Scope: only this repo, Contents: Read+Write only.
GITHUB_TOKEN=
GITHUB_REPO=epiphanydigitalmedia/unlimitpodcast
GITHUB_BRANCH=main

# Cron secret — random string used by Vercel Cron to auth to the endpoint.
# Generate with: openssl rand -hex 32
CRON_SECRET=
